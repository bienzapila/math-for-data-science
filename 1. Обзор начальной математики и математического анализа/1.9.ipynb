      "6*x**2\n",
      "9*y**2\n"
     ]
    }
   ],
   "source": [
    "x, y = symbols('x y')\n",
    "f = 2 * x ** 3 + 3 * y ** 3\n",
    "x_df = diff(f, x)\n",
    "y_df = diff(f, y)\n",
    "print(x_df, y_df, sep='\\n')"
   ]
